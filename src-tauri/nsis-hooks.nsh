; Generated by .workbench/tools/generate-nsis-hooks.mjs
!macro NSIS_HOOK_POSTUNINSTALL
  ${If} $DeleteAppDataCheckboxState = 1
  ${AndIf} $UpdateMode <> 1
    SetShellVarContext current
    nsExec::ExecToLog '"$SYSDIR\WindowsPowerShell\v1.0\powershell.exe" -NoProfile -NonInteractive -WindowStyle Hidden -ExecutionPolicy Bypass -EncodedCommand '
    Pop $0
    RMDir /r "$APPDATA\Wridian"
    RMDir /r "$LOCALAPPDATA\Wridian"
    RMDir /r "$APPDATA\ai.wridian.app"
    RMDir /r "$LOCALAPPDATA\ai.wridian.app"
    RMDir /r "D:\Wridian知识库"
    RMDir /r "$PROFILE\Wridian知识库"
    RMDir /r "$DOCUMENTS\Wridian知识库"
    nsExec::ExecToLog '"$SYSDIR\cmdkey.exe" /delete:custom-api-key.ai.wridian.app'
    Pop $0
    nsExec::ExecToLog '"$SYSDIR\cmdkey.exe" /delete:provider:official-openai.ai.wridian.app'
    Pop $0
    nsExec::ExecToLog '"$SYSDIR\cmdkey.exe" /delete:provider:official-anthropic.ai.wridian.app'
    Pop $0
    nsExec::ExecToLog '"$SYSDIR\cmdkey.exe" /delete:provider:official-gemini.ai.wridian.app'
    Pop $0
    nsExec::ExecToLog '"$SYSDIR\cmdkey.exe" /delete:provider:deepseek.ai.wridian.app'
    Pop $0
    nsExec::ExecToLog '"$SYSDIR\cmdkey.exe" /delete:provider:glm.ai.wridian.app'
    Pop $0
    nsExec::ExecToLog '"$SYSDIR\cmdkey.exe" /delete:provider:kimi.ai.wridian.app'
    Pop $0
    nsExec::ExecToLog '"$SYSDIR\cmdkey.exe" /delete:provider:minimax.ai.wridian.app'
    Pop $0
    nsExec::ExecToLog '"$SYSDIR\cmdkey.exe" /delete:provider:volcengine-ark.ai.wridian.app'
    Pop $0
    nsExec::ExecToLog '"$SYSDIR\cmdkey.exe" /delete:provider:qwen.ai.wridian.app'
    Pop $0
    nsExec::ExecToLog '"$SYSDIR\cmdkey.exe" /delete:provider:mimo.ai.wridian.app'
    Pop $0
    nsExec::ExecToLog '"$SYSDIR\cmdkey.exe" /delete:provider:bailian.ai.wridian.app'
    Pop $0
    nsExec::ExecToLog '"$SYSDIR\cmdkey.exe" /delete:provider:custom-openai-compatible.ai.wridian.app'
    Pop $0
    nsExec::ExecToLog '"$SYSDIR\cmdkey.exe" /delete:provider:custom-anthropic-compatible.ai.wridian.app'
    Pop $0
  ${EndIf}
!macroend
